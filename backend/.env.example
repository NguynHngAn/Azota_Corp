# App
APP_NAME=Azota-like Exam API
ENV=development
DEBUG=false

# Password reset links (SPA)
FRONTEND_BASE_URL=http://localhost:5173
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

# JWT
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=postgresql://postgres:your_password@localhost:5432/azota_exam

# Anti-cheat (optional tuning)
ANTI_CHEAT_MAX_VIOLATIONS=10
ANTI_CHEAT_ENFORCE=true
ANTI_CHEAT_EVENT_RATE_WINDOW_SECONDS=60
ANTI_CHEAT_EVENT_RATE_MAX=120
ANTI_CHEAT_HEARTBEAT_STALE_SECONDS=30

# Built-in timeout finalizer fallback (seconds)
EXAM_TIMEOUT_FINALIZER_ENABLED=true
EXAM_TIMEOUT_FINALIZER_INTERVAL_SECONDS=20

# Gemini AI
GEMINI_API_KEY=your_google_ai_studio_key
GEMINI_MODEL=gemini-2.5-flash
